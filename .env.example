# Privy — wallet auth (https://dashboard.privy.io)
VITE_PRIVY_APP_ID=your-privy-app-id

# Supabase — realtime game state
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Solana — network + RPC
# Set to mainnet-beta for production, devnet for testing
VITE_SOLANA_NETWORK=devnet
VITE_SOLANA_RPC=https://devnet.helius-rpc.com/?api-key=your-helius-api-key

# MagicBlock Ephemeral Rollups — faster tx confirmations
# Devnet: https://devnet-router.magicblock.app
# Mainnet: https://mainnet-router.magicblock.app (when available)
VITE_MAGICBLOCK_ROUTER=https://devnet-router.magicblock.app
VITE_MAGICBLOCK_WS=wss://devnet-router.magicblock.app
