# Privy — wallet auth (https://dashboard.privy.io)
VITE_PRIVY_APP_ID=your-privy-app-id

# Supabase — realtime game state
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Solana — network + RPC
# Set to mainnet-beta for production, devnet for testing
VITE_SOLANA_NETWORK=devnet
VITE_SOLANA_RPC=https://devnet.helius-rpc.com/?api-key=your-helius-api-key

# MagicBlock Ephemeral Rollups — faster tx confirmations
# Devnet: https://devnet-router.magicblock.app
# Mainnet: https://mainnet-router.magicblock.app (when available)
VITE_MAGICBLOCK_ROUTER=https://devnet-router.magicblock.app
VITE_MAGICBLOCK_WS=wss://devnet-router.magicblock.app

# Trustless escrow — PDA-based pot management (set to true to enable)
# When enabled, buy-ins go to an escrow PDA instead of the host wallet.
# Requires the Anchor program deployed at the PROGRAM_ID in anchor-escrow.ts
# Locked direction (2026-06-19): trustless escrow is the default. Program is
# deployed + verified on devnet at 2zPLNqsyqXNxaMkzWUMh1ZcbJBR3Jr2bTky1FFaZVuF9.
VITE_USE_ESCROW=true

# Escrow hardening — Edge-Function-gated phase advance + settlement.
# Enable ONLY after: (1) applying supabase/migrations/20260701_escrow_hardening.sql,
# (2) deploying the advance-phase + settle-game Edge Functions,
# (3) redeploying the Anchor program (settlement_authority support).
VITE_USE_EDGE_GAME_AUTH=false

# Public key (base58) of the settle-game function's devnet keypair. Baked into
# each game at creation; the program lets it call distribute (payouts only).
# Leave empty for host-only distribution. This is PUBLIC info — the secret key
# lives only in Supabase secrets (SETTLEMENT_SECRET_KEY), never in the client.
VITE_SETTLEMENT_AUTHORITY=
